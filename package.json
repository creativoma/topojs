{
  "name": "topo",
  "private": true,
  "version": "0.1.0",
  "description": "State management as graph topology, not tree hierarchy",
  "keywords": [
    "state-management",
    "graph",
    "topology",
    "typescript",
    "react"
  ],
  "homepage": "https://github.com/creativoma/topojs",
  "bugs": {
    "url": "https://github.com/creativoma/topojs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creativoma/topojs.git"
  },
  "license": "MIT",
  "author": "Mariano Alvarez",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "validate": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "validate:fix": "pnpm run format && pnpm run lint -- --fix && pnpm run typecheck && pnpm run test",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "example": "pnpm --filter @topojs/example-cart dev",
    "website": "pnpm --filter @topojs/website dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
